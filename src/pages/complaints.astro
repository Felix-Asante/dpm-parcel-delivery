---
import Layout from '../layouts/Layout.astro';
import { ComplaintForm } from '../sections/complaints/ComplaintForm';
---

<Layout title="Log a complaint">
  <main class="min-h-[60vh] py-12 md:py-16 px-4 sm:px-6 lg:px-8">
    <div class="lg:max-w-6xl 2xl:max-w-7xl mx-auto">
      <header class="mb-10 max-w-2xl">
        <p class="text-primary font-semibold text-sm uppercase tracking-wide mb-2">
          Support
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-secondary">
          Log a complaint
        </h1>
        <p class="mt-3 text-neutral-600 text-base md:text-lg">
          Tell us what went wrong with your delivery. We read every submission and
          use your details to investigate and get back to you.
        </p>
      </header>
      <ComplaintForm client:visible />
    </div>
  </main>
</Layout>
